{
    "layout": {
        "type": "layout",
        "pages": ["main", "advanced"],
        "main": {
            "type": "page",
            "title": "Geral",
            "sections": ["calendars-section", "panel-section", "privacy-section"]
        },
        "advanced": {
            "type": "page",
            "title": "Avancado",
            "sections": ["notifications-section", "refresh-section"]
        },
        "calendars-section": {
            "type": "section",
            "title": "Calendarios",
            "keys": ["calendars"]
        },
        "panel-section": {
            "type": "section",
            "title": "Painel e Popup",
            "keys": ["show-in-panel", "label-max-chars", "show-tentative"]
        },
        "privacy-section": {
            "type": "section",
            "title": "Privacidade",
            "keys": ["hidden-mode"]
        },
        "notifications-section": {
            "type": "section",
            "title": "Notificacoes",
            "keys": ["notify-enabled", "notify-before", "notify-conflicts"]
        },
        "refresh-section": {
            "type": "section",
            "title": "Atualizacao",
            "keys": ["refresh-interval"]
        }
    },
    "calendars": {
        "type": "list",
        "description": "Calendarios Outlook (URLs ICS publicas)",
        "columns": [
            { "id": "name",    "title": "Nome",       "type": "string" },
            { "id": "url",     "title": "URL ICS",    "type": "string" },
            { "id": "color",   "title": "Cor (hex)",  "type": "string" },
            { "id": "enabled", "title": "Ativo",      "type": "boolean" }
        ],
        "default": []
    },
    "show-in-panel": {
        "type": "switch",
        "default": true,
        "description": "Exibir texto na barra (desligue para Modo Sem Exibicao - so icone)"
    },
    "label-max-chars": {
        "type": "spinbutton",
        "default": 40,
        "min": 10,
        "max": 100,
        "step": 1,
        "units": "caracteres",
        "description": "Tamanho maximo do texto na barra"
    },
    "show-tentative": {
        "type": "switch",
        "default": true,
        "description": "Exibir reunioes pendentes/tentativas no popup"
    },
    "hidden-mode": {
        "type": "switch",
        "default": false,
        "description": "Modo Oculto: mostra apenas o tempo restante (countdown), omite nome e horario da reuniao na barra. Util para compartilhamento ou gravacao de tela."
    },
    "notify-enabled": {
        "type": "switch",
        "default": true,
        "description": "Notificar antes da reuniao"
    },
    "notify-before": {
        "type": "spinbutton",
        "default": 30,
        "min": 1,
        "max": 120,
        "step": 1,
        "units": "minutos",
        "description": "Antecedencia da notificacao"
    },
    "notify-conflicts": {
        "type": "switch",
        "default": true,
        "description": "Notificar quando houver conflito de horarios (urgencia critica)"
    },
    "refresh-interval": {
        "type": "spinbutton",
        "default": 5,
        "min": 1,
        "max": 60,
        "step": 1,
        "units": "minutos",
        "description": "Intervalo de atualizacao do calendario"
    }
}
